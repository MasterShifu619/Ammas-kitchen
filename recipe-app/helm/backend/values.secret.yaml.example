# values.secret.yaml — DO NOT commit real values.
# Copy this file to values.secret.yaml locally and fill in real values,
# or inject via --set flags in CI pipelines.  This file is gitignored.

image:
  repository: "123456789012.dkr.ecr.us-east-1.amazonaws.com/ammas-kitchen/backend"
  tag: "abc1234"

ingress:
  host: "api.ammas-kitchen.yourdomain.com"
  tls:
    - secretName: ammas-kitchen-api-tls
      hosts:
        - api.ammas-kitchen.yourdomain.com

secrets:
  dbSecretName: "ammas-kitchen/db-credentials"
  s3BucketName: "ammas-kitchen-recipes-123456789012"

serviceAccount:
  annotations:
    eks.amazonaws.com/role-arn: "arn:aws:iam::123456789012:role/ammas-kitchen-backend"
